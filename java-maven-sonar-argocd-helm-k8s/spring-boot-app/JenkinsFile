pipeline {
agent {
    docker {
      // Changed to an official Maven image running Java 17
      image 'maven:3.9.6-eclipse-temurin-17'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock -v $HOME/.m2:/root/.m2 --entrypoint=\'\'' 
    }
  }
  
  // Best Practice: Move global variables to a top-level environment block
  environment {
    SONAR_URL     = "http://192.168.29.173:9000"
    DOCKER_IMAGE  = "nsr84/ultimate-cicd:${BUILD_NUMBER}"
    GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
    GIT_USER_NAME = "nsr94" // Corrected to your GitHub username
  }

  stages {
    stage('Checkout') {
      steps {
        // FIX 3: Uncommented and properly configured the checkout step
        git branch: 'main', url: "https://github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git"
      }
    }

    stage('Build and Test') {
  steps {
    // Delete the specific corrupted package or the entire repository cache
    sh 'rm -rf /root/.m2/repository/commons-lang/commons-lang/'
    // OR wipe everything: sh 'rm -rf /root/.m2/repository/*'
    
    sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn clean package -U'
  }
}

    stage('Static Code Analysis') {
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
        }
      }
    }

    stage('Build and Push Docker Image') {
      steps {
        script {
          // FIX 5: Streamlined Docker build & push using Jenkins Docker Pipeline Plugin
          docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
            def appImage = docker.build("${DOCKER_IMAGE}", "java-maven-sonar-argocd-helm-k8s/spring-boot-app")
            appImage.push()
          }
        }
      }
    }

    stage('Update Deployment File') {
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh '''
            # Set local git config for the commit
            git config user.email "nrndrsingh1994@gmail.com"
            git config user.name "${GIT_USER_NAME}"
            
            # Update the image tag in the manifest file
            sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
            
            # Commit the change
            git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
            git commit -m "Update deployment image to version ${BUILD_NUMBER}"
            
            # FIX 6: Use the correct repository URL for the push
            git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:main
          '''
        }
      }
    }
  }
}
